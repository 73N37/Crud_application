<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Define log file paths and names -->
    <property name="LOG_PATH" value="logs" />
    <property name="LOG_FILE" value="crudapp" />

    <!-- 🎨 CONSOLE APPENDER: Color-coded and formatted for development -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %magenta([%thread]) %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 📂 FILE APPENDER: Rolling file appender for production persistence -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rollover with size-based triggering -->
            <fileNamePattern>${LOG_PATH}/archived/${LOG_FILE}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 🏗️ FRAMEWORK LOGGING: Standard Spring and Hibernate levels -->
    <logger name="org.springframework" level="INFO" />
    <logger name="org.hibernate.SQL" level="DEBUG" />
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE" />

    <!-- 🧠 APP LOGGING: High granularity for our Meta-Programming engine -->
    <logger name="com.example.crudapp" level="DEBUG" />
    
    <!-- 🔒 SECURITY LOGGING: Track authentication and access attempts -->
    <logger name="org.springframework.security" level="INFO" />

    <!-- ROOT LEVEL: Default to INFO -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
